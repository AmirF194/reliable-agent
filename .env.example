# Copy to .env and fill in. Never commit real keys.

# --- Backend selection ---
AGENT_BACKEND=claude          # claude | cohere

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# --- Cohere ---
COHERE_API_KEY=
COHERE_MODEL=command-a-03-2025

# --- Agent limits (hard ceilings) ---
AGENT_MAX_TOKENS=4096
AGENT_MAX_STEPS=10
AGENT_MAX_RETRIES=4
AGENT_TIMEOUT=60
